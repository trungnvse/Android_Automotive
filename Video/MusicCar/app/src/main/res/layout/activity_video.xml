<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- PlayerView full màn hình làm nền -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"/>

    <!-- Tab bar trong suốt, đè lên video phía trên -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#AA000000"
        android:layout_alignParentTop="true">

        <Button
            android:id="@+id/btnTabMusic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🎵 NHẠC"
            android:textColor="#AAAAAA"
            android:backgroundTint="@android:color/transparent"/>

        <Button
            android:id="@+id/btnTabVideo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🎬 VIDEO"
            android:textColor="#E94560"
            android:backgroundTint="@android:color/transparent"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Control panel trong suốt, đè lên video phía dưới -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="10dp"
        android:layout_alignParentBottom="true">

        <!-- Tên + tác giả -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvVideoTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chưa có video"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvVideoArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unknown"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- SeekBar tiến trình -->
        <SeekBar
            android:id="@+id/seekBarVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#E94560"
            android:thumbTint="#E94560"
            android:layout_marginBottom="4dp"/>

        <!-- Thời gian -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvVideoCurrentTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="#AAAAAA"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvVideoTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#AAAAAA"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Hàng controls: Prev/Play/Next + Volume -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Playback buttons -->
            <Button
                android:id="@+id/btnVideoPrev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="⏮"
                android:textSize="16sp"
                android:backgroundTint="#44FFFFFF"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnVideoPlayPause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="▶"
                android:textSize="20sp"
                android:backgroundTint="#E94560"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnVideoNext"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="⏭"
                android:textSize="16sp"
                android:backgroundTint="#44FFFFFF"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="20dp"/>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:background="#55FFFFFF"
                android:layout_marginEnd="20dp"/>

            <!-- Volume label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOL"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginEnd="8dp"/>

            <!-- Nút giảm -->
            <Button
                android:id="@+id/btnVideoVolumeDown"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="-"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#44FFFFFF"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <!-- SeekBar volume -->
            <SeekBar
                android:id="@+id/seekBarVideoVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="80"
                android:progressTint="#E94560"
                android:thumbTint="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <!-- Phần trăm -->
            <TextView
                android:id="@+id/tvVideoVolumePercent"
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="80%"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="8dp"/>

            <!-- Nút tăng -->
            <Button
                android:id="@+id/btnVideoVolumeUp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="+"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#44FFFFFF"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>